{
  "name": "cacic-fct",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "dev": "docusaurus start --no-open",
    "build:analytics": "mkdir -p static/js && bun build src/analytics/cacic-umami-tracking.ts --target=browser --format=iife --outfile=static/js/cacic-umami-tracking.js --minify",
    "build": "bun run build:analytics && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "bun run build:analytics && docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint": "oxlint . --ignore-path=.oxlintignore --import-plugin --react-plugin --jsx-a11y-plugin --deny-warnings",
    "lint:fix": "oxlint . --ignore-path=.oxlintignore --import-plugin --react-plugin --jsx-a11y-plugin --fix",
    "format": "oxfmt --config=.oxfmtrc.json . --write",
    "format:check": "oxfmt --config=.oxfmtrc.json . --check",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@cacic-fct/account-manager-cookie-banner": "^0.0.1",
    "@cacic-fct/account-manager-privacy": "0.0.2",
    "@docusaurus/core": "^3.8.0",
    "@docusaurus/faster": "^3.9.1",
    "@docusaurus/plugin-content-docs": "^3.8.0",
    "@docusaurus/preset-classic": "^3.8.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mdx-js/react": "^3.1.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@mui/x-date-pickers": "^8.5.2",
    "caniuse-lite": "^1.0.30001720",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "docusaurus-theme-search-typesense": "^0.22.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-twitch-embed": "^3.0.2"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.8.0",
    "@docusaurus/tsconfig": "^3.8.0",
    "@docusaurus/types": "^3.8.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "~5.6.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  },
  "trustedDependencies": [
    "core-js",
    "core-js-pure"
  ]
}
